{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@mycode/cli": ["./packages/cli/src"],
      "@mycode/cli/*": ["./packages/cli/src/*"],
      "@mycode/core": ["./packages/core/src"],
      "@mycode/core/*": ["./packages/core/src/*"],
      "@mycode/sdk": ["./packages/sdk/src"],
      "@mycode/sdk/*": ["./packages/sdk/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
