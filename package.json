{
  "name": "mycode-ai",
  "version": "1.0.0-alpha",
  "private": true,
  "description": "Multi-provider AI coding agent for the terminal. Like Claude Code, but provider-agnostic with automatic failover.",
  "type": "module",
  "workspaces": [
    "packages/cli",
    "packages/core",
    "packages/sdk",
    "packages/a2a-server",
    "packages/devtools",
    "packages/test-utils"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:cli": "node scripts/build.mjs --package cli",
    "build:core": "node scripts/build.mjs --package core",
    "build:sdk": "node scripts/build.mjs --package sdk",
    "clean": "rimraf packages/*/dist",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node packages/cli/dist/mycode.js",
    "dev": "node --watch packages/cli/dist/mycode.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "cli",
    "terminal",
    "openrouter",
    "ollama",
    "nvidia-nim",
    "agent",
    "code-assistant",
    "gemini-cli"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
